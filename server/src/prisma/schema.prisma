// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String        @id @default(uuid())
  name              String
  username          String        @unique
  email             String        @unique
  password          String
  bio               String?
  avatarUrl         String?
  isPublic          Boolean       @default(true)
  verificationToken Int?          @unique
  resetToken        String?       @unique
  isVerified        Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  posts             Post[]
  comments          Comment[]
  postLikes         PostLike[]
  repliesByUser     Reply[]       @relation("author")
  repliesToUser     Reply[]       @relation("replyTo")
  commentLikes      CommentLike[]
  replyLikes        ReplyLike[]

  @@map("users")
}

model Post {
  id        String     @id @default(uuid())
  caption   String?
  imageUrls String[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  authorId  String
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  Comment[]
  postLikes PostLike[]

  @@map("posts")
}

model Comment {
  id           String        @id @default(uuid())
  content      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  authorId     String
  author       User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId       String
  post         Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  replies      Reply[]
  commentLikes CommentLike[]

  @@map("comments")
}

model Reply {
  id         String      @id @default(uuid())
  content    String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  commentId  String
  comment    Comment     @relation(fields: [commentId], references: [id], onDelete: Cascade)
  authorId   String
  author     User        @relation("author", fields: [authorId], references: [id], onDelete: Cascade)
  replyToId  String
  replyTo    User        @relation("replyTo", fields: [replyToId], references: [id])
  replyLikes ReplyLike[]

  @@map("replies")
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  likerId   String
  liker     User     @relation(fields: [likerId], references: [id])
  createdAt DateTime @default(now())

  @@map("post_likes")
}

model CommentLike {
  id        String   @id @default(uuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id])
  likerId   String
  liker     User     @relation(fields: [likerId], references: [id])
  createdAt DateTime @default(now())

  @@map("comment_likes")
}

model ReplyLike {
  id        String   @id @default(uuid())
  replyId   String
  reply     Reply    @relation(fields: [replyId], references: [id])
  likerId   String
  liker     User     @relation(fields: [likerId], references: [id])
  createdAt DateTime @default(now())

  @@map("reply_likes")
}
